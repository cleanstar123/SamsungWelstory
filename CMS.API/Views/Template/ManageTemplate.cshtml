                                        if (productCategory != 'IMAGE') {
                                            $(contetnsAreaEle[i]).html('&nbsp;');
                                        }
                                    }
                                    else {
                                        // 2019-04-24 평가점수 Image
                                        $(contetnsAreaEle[i]).parent().parent().css('visibility', 'hidden');
                                    }
                                }
                            }
                            else {

                                $(contetnsAreaEle[0]).parent().parent().addClass('active').removeClass('select');
                                if (contentsAreatype != 'DATE') {
                                    $(contetnsAreaEle[0]).parent().parent().css('visibility', 'hidden');
                                }
                            }
                        }
                    }
                }
            }
        })();


