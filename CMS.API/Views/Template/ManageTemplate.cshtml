                        // 메뉴를 로컬 이지를 연결 했을 경우
                        else if (contentsType == 'P' && connectionType == 'L') {


                            for (var i = 0; i < elements.length; i++) {

                                switch ($(elements[i]).data('product-category').toUpperCase()) {
                                    case 'IMAGE':
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).empty();
                                        $(elements[i]).append($('<img src="' + $('#M_PHOTO_CD').attr('src') + '" alt="" />'));


                                        break;
                                    case 'NAME':
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).html(contetnsData.MENU_NM ? contetnsData.MENU_NM : '&nbsp;');
                                        break;
                                    case 'ENAME':
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).html(contetnsData.MENU_NM_ENG ? contetnsData.MENU_NM_ENG : '&nbsp;');
                                        break;
                                    case 'PRICE':
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).html(contetnsData.MENU_PRICE ? '\\ ' + contetnsData.MENU_PRICE : '&nbsp;');
                                        break;
                                    case 'SIDEDISH':
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).html(contetnsData.SIDE_DISH ? '부찬 : ' + contetnsData.SIDE_DISH : '&nbsp;');
                                        break;
                                    case 'KCAL':
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).html(contetnsData.MENU_KCAL ? '칼로리 ' + contetnsData.MENU_KCAL + ' Kcal' : '&nbsp;');
                                        break;
                                    case 'SCORE1':
                                    case 'SCORE2':
                                    case 'SCORE3':
                                    case 'SCORE4':
                                    case 'SCORE5':
                                        // 2019-04-24 평가점수 Image
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).parent().parent().css('visibility', 'visible');

                                        $(elements[i]).attr('data-restaurant-code', '');
                                        $(elements[i]).attr('data-menu-dt',   '');
                                        $(elements[i]).attr('data-meal-type', '');
                                        $(elements[i]).attr('data-menu-cd',   '');
                                        $(elements[i]).attr('data-course',    '');
                                        $(elements[i]).attr('data-hall-no',   '');
                                        break;
                                }
                            }
                        }
                        // 컨텐츠 영역이 뱃지, 헤드라인, 이미지고 시스템 컨텐츠와 연결시
                        else if ((contentsType == 'B' || contentsType == 'H' || contentsType == 'I') && connectionType == 'C') {
                            $(elements[0]).parent().parent().addClass('active');
                            $(elements[0]).empty();
                            $(elements[0]).append($('<img src="' + contetnsData.FILE_URL + '" alt="" />'));
                        }
                        else if (contentsType == 'M' && connectionType == 'C') {
