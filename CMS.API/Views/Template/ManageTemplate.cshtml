                <select id="MEAL_TYPE">
                    <option value="1">조식</option>
                    <option value="2">중식</option>
                    <option value="3">석식</option>
                    <option value="4">야식</option>
                    <option value="5">간식</option>
                    <option value="6">기타식</option>
                </select>
            </div>
            <!-- 컨텐츠 결과 화면 -->
            <ul id="welMenuResultArea" class="popup_conList"></ul>
            <!--// 컨텐츠 결과 화면 -->
        </div>
        <div class="step_button">
            <p class="a_btn_wrap">
                <a class="a_btn btn_style3" href="javascript:manageWelMenu.popups.nextStep();">다음 단계</a>
                <a class="a_btn btn_style3" href="javascript:manageWelMenu.popups.jbWelMenu.close(); void 0">취소</a>
            </p>
        </div>
    </div>
    <!--// 게시 메뉴 연결 01 Step -->
    <!-- 게시 메뉴 연결 02 Step -->
    <div class="pop_sc_2">
        <div class="popup_area">
            <div class="popup_contents">
                <table>
                    <tr>
                        <td>이미지</td>
                        <td>
                            <div class="image_area">
                                <img id="M_PHOTO_CD" alt="" />
                            </div>

                        </td>
                    </tr>
                    <tr>
                        <td>이미지 변경</td>
                        <td><input type="file" id="localfile" onchange="previewFile()" style="padding-left: 0px;" accept="image/*" /></td>
                    </tr>
                    <tr>
                        <td>음식명</td>
                        <td>
                            <input type="text" id="M_MENU_NM">
                        </td>
                    </tr>
                    <tr>
                        <td>영문 음식명</td>
                        <td><input type="text" id="M_MENU_NM_ENG"></td>
                    </tr>
                    <tr>
                        <td>가격</td>
                        <td><input type="text" id="M_MENU_PRICE"></td>
                    </tr>
                    <tr>
                        <td>부찬</td>
                        <td><input type="text" id="M_SIDE_DISH"></td>
                    </tr>
                    <tr>
                        <td>칼로리</td>
                        <td><input type="text" id="M_MENU_KCAL"></td>
                    </tr>
                </table>
            </div>
            <div class="step_button">
                <p class="a_btn_wrap">
                    <a class="a_btn btn_style3" href="javascript:manageWelMenu.popups.prevStep();">이전 단계</a>
                    <a class="a_btn btn_style3" href="javascript:manageWelMenu.popups.apply();">연결</a>
                    <a class="a_btn btn_style3" href="javascript:manageWelMenu.popups.jbWelMenu.close(); void 0">취소</a>
                </p>
            </div>
        </div>
    </div>

    <!--// 게시 메뉴 연결 02 Step -->

    <canvas id="localImageCanvas" style="display:none;"></canvas>
</div>


@* 컨텐츠 연결 팝업 *@
<div id="jbContents" class="popup1" style="display: none">

    <div class="pop_sc_1">
        <div class="popup_subCnt">
            <div class="bul_wrap">
                <div class="f_r">
                    <a class="a_btn btn_style2" href="javascript:manageContents.searchContetns(1);"><em></em>조회</a>
                </div>
            </div>
            <div class="search_area">
                <label for=""><em></em>컨텐츠 타입</label>
                <select id="CONTENT_TYPE" disabled>
                    <option value="B">뱃지</option>
                    <option value="H">헤드라인</option>
                    <option value="I">이미지</option>
                    <option value="M">동영상</option>
                    <option value="U">URL</option>
                    <option value="T">텍스트</option>
                </select>
                <label for=""><em></em>컨텐츠 이름</label>
                <input type="text" id="CONTENT_NM">

            </div>
            <!-- 컨텐츠 결과 화면 -->
            <ul id="contentsResultArea" class="popup_conList popup_conList2"></ul>
            <!--// 컨텐츠 결과 화면 -->
            <ul class="paging"></ul>
        </div>
        <div class="step_button">
            <p class="a_btn_wrap">
                <a class="a_btn btn_style3" href="javascript:manageContents.popups.apply();">연결</a>
                <a class="a_btn btn_style3" href="javascript:manageContents.popups.jbContents.close(); void 0">취소</a>
            </p>
        </div>
    </div>
</div>


<div id="jbTemplate" class="popup10" style="display:none;">
    <div class="popup_area">
        <div class="popup_contents">
            <table>
                <tr>
                    <td>템플릿 이름</td>
                    <td><input type="text" id="M_TEMPLATE_NM" value="@Model.TEMPLATE_NM" maxlength="60"></td>
                </tr>
                <tr>
                    <td>템플릿 설명</td>
                    <td><input type="text" id="M_TEMPLATE_DESC" value="@Model.TEMPLATE_DESC" maxlength="60"></td>
                </tr>
            </table>
        </div>
        <div class="step_button">
            @if (ViewBag.type == "U")
            {
                <a class="a_btn btn_style3" href="javascript:manageTemplate.saveTemplate('U');">수정</a>
            }
            else
            {
                <a class="a_btn btn_style3" href="javascript:manageTemplate.saveTemplate('I');">저장</a>
            }
            <a class="a_btn btn_style3" href="javascript:manageTemplate.popups.jbTemplate.close(); void 0">취소</a>
        </div>
    </div>
</div>




@section scripts
{
    <script>

        // 레이아웃의 이미지 경로를 수정
        $(document).ready(function () {

            if ('@ViewBag.type' == 'I') {
                // 스타일로 background-image 를 설정한 경우 경로 수정
                $('#templateArea, #templateArea *').each(function () {

                    if ($(this).css('background-image') != 'none') {

                        var names = $(this).css('background-image').split('/');
                        var name = names[names.length - 1].replace('")', "");

                        $(this).css('background-image', "url('" + '/upload/layout/' + '@Model.layoutModel.LAYOUT_ID' + '/images/' + name + "')");
                    }
                });

                /* 이미지 경로 수정 */
                $('#layer img').each(function () {
                    var src = $(this).attr('src');
                    var names = src.split('/');
                    var name = names[names.length - 1];

                    $(this).attr('src', '/upload/layout/' + '@Model.layoutModel.LAYOUT_ID' + '/images/' + name);
                });
            }
            else { /* 템플릿 수정일 경우 */

                $('#templateArea').each(function () {

                    if ($(this).css('background-image') != 'none') {

                        var names = $(this).css('background-image').split('/');
                        var name = names[names.length - 1].replace('")', "");

                        $(this).css('background-image', "url('" + '/upload/layout/' + '@Model.layoutModel.LAYOUT_ID' + '/images/' + name + "')");
                    }
                });
            }
        });


        // 현재 컨텐츠 연결 상태 (W : 메뉴게시, C : 시스템 컨텐츠, L : 로컬)
        var connectionType = '';


        /* 템플릿 관리 */
        var manageTemplate = (function () {

            return {
                contetnsAreaId: '',
                contetnsAreaType: '',
                contentsAreaInfo: {},    // 현재 레이아웃의 컨텐츠 영역 정보를 관리
                // 모델 정의
                models: {
                    // 템플릿 기본 정보
                    TemplateModel: function() {
                        this.RESTAURANT_CODE = '@ViewBag.RESTAURANT_CD';
                        this.TEMPLATE_ID     = '@Model.TEMPLATE_ID';
                        this.TEMPLATE_NM     = '';
                        this.TEMPLATE_DESC   = '';
                        this.TEMPLATE_HTML   = '';
                        this.LAYOUT_ID       = '@Model.layoutModel.LAYOUT_ID';
                        this.SCREEN_W        = '@Model.layoutModel.SCREEN_W';
                        this.SCREEN_H        = '@Model.layoutModel.SCREEN_H';
                    },
                    // 템플릿 컨텐츠 연결 정보
                    TemplateMapModel: function () {
                        this.RESTAURANT_CODE = '@ViewBag.RESTAURANT_CD';
                        this.TEMPLATE_ID     = '';
                        this.LAYOUT_ID       = '';
                        this.CONTENT_SEQ     = '';
                        this.CONTENT_ID      = '';
                        this.CONTENT_TYPE    = '';
                        this.CONNECTION_TYPE = '';
                        this.CONNECTION_NM   = '';
                        this.IS_UPDATE       = true;
                    }
                },
                // 화면에서 사용하는 요소 정의
                elements: {
                    $selContentsType : $('#selContentsType'),
                    $M_TEMPLATE_NM   : $('#M_TEMPLATE_NM'),
                    $M_TEMPLATE_DESC : $('#M_TEMPLATE_DESC')
                },
                // 요소 초기화 함수
                init: function () {
                    if('@ViewBag.type' == 'I') {
                        manageTemplate.elements.$M_TEMPLATE_NM.val('');
                        manageTemplate.elements.$M_TEMPLATE_DESC.val('');
                    }
                    else {
                        manageTemplate.elements.$M_TEMPLATE_NM.val("@Model.TEMPLATE_NM");
                        manageTemplate.elements.$M_TEMPLATE_DESC.val("@Model.TEMPLATE_DESC");
                    }

                },
                popups: {
                    jbTemplate: new jBox('Modal', {
                        draggable          : 'title',
                        dragOver           : false,
                        closeOnEsc         : true,
                        isolateScroll      : false,
                        attach             : '#myModal',
                        title              : '템플릿 저장',
                        content            : $('#jbTemplate'),
                        closeButton        : 'title',
                        width              : "15%",
                        height             : "10%",
                        minWidth           : 450,
                        minHeight          : 150,
                        responsiveMinWidth : 450,
                        responsiveMinHeight: 150,
                        responsiveWidth    : false,
                        responsiveHeight   : false
                    }),
                    showJBTemplate: function () {
                        manageTemplate.init();
                        manageTemplate.popups.jbTemplate.open();
                        manageTemplate.elements.$M_TEMPLATE_NM.focus();
                    }
                },
                // 컨텐츠 영역 클릭시 팝업 호출 (메뉴게시 팝업, 컨텐츠 팝업 판단)
                showPopup: function (contentsAreaType, contentsSeq) {

                    // 날짜 영역의 경우 팝업 열지 않음
                    if (contentsAreaType == 'D') {
                        return;
                    }

                    manageTemplate.contetnsAreaId   = contentsSeq;       // 현재 선택된 컨텐츠 영역 아이디를 할당
                    manageTemplate.contetnsAreaType = contentsAreaType;  // 현재 선택된 컨텐츠 영역 타입을 할당

                    // 메뉴 컨텐츠 영역일 경우
                    if (manageTemplate.contetnsAreaType == 'P') {
                        connectionType = 'W';
                        manageWelMenu.popups.showJBWelMenu(contentsAreaType, contentsSeq);
                    }
                    // 일반 컨텐츠 영역일 경우
                    else {
                        connectionType = 'C';
                        manageContents.popups.showJBContetns();
                    }
                },
                // 레이아웃 정보 셋팅 함수
                setContetnsAreaInfo: function () {

                    // 생성일 경우 레이아웃 정보 셋팅
                    if ('@ViewBag.type' == 'I') {
                        $('[data-contents-area-id]').each(function () {

                            var contentsAreaId =       $(this).data('contents-area-id');                      // 컨텐츠 영역 아이디
                            var contentsAreaType =     $(this).data('contents-area-type');                    // 컨텐츠 영역 타입
                            var contentsAreaElements = $('[data-contents-area-id="' + contentsAreaId + '"]'); // 모든 컨텐츠 영역

                            // 컨텐츠 영역 정보
                            manageTemplate.contentsAreaInfo[contentsAreaId] = {
                                type          : contentsAreaType,
                                elements      : contentsAreaElements,
                                connectionData: {},
                                connectionType: ''
                            };

                            // console.log(contentsAreaId, contentsAreaType);

                            $(this).parent().parent().mouseover(function () { $(contentsAreaElements).parent().parent().addClass('select'); });
                            $(this).parent().parent().mouseout(function ()  { $(contentsAreaElements).parent().parent().removeClass('select'); });

                            // 컨텐츠 영역 클릭시 해당하는 연결 팝업 호출
                            $(this).parent().parent().click(function () {

                                // 날짜 형식의 경우 팝업 제외
                                if (contentsAreaType.toUpperCase().substring(0, 1) == 'D')
                                    return;

                                manageTemplate.showPopup(contentsAreaType.toUpperCase().substring(0, 1), contentsAreaId);
                            });

                            $(this).parent().parent().css('cursor', 'pointer');

                        });
                    }
                    // 수정일 경우 템플릿 정보 셋팅
                    else {
                        var templateMapModels = @Html.Raw(Json.Encode(Model.templateMapModels));

                        var templateMapData = {};

                        for (var i = 0; i < templateMapModels.length; i++) {
                            templateMapData[templateMapModels[i].LAYOUT_SEQ] = templateMapModels[i];
                        }

                        // console.log(templateMapData);

                        $('[data-contents-area-id]').each(function () {

                            var contentsAreaId       = $(this).data('contents-area-id');                                 // 컨텐츠 영역 아이디
                            var contentsAreaType     = $(this).data('contents-area-type');                               // 컨텐츠 영역 타입
                            var contentsAreaTypeCode = $(this).data('contents-area-type').toUpperCase().substring(0, 1); // 컨텐츠 영역 타입
                            var contentsAreaElements = $('[data-contents-area-id="' + contentsAreaId + '"]');            // 모든 컨텐츠 영역

                            var contentsData              = {};
                            var connectionType            = '';
                            var TEMPLATE_CONTENTS_FILE_NM = '';

                            // 연결 정보가 있을 경우
                            if (templateMapData[contentsAreaId]) {

                                connectionType = templateMapData[contentsAreaId].CONNECTION_TYPE;

                                if (templateMapData[contentsAreaId].CONNECTION_TYPE == 'C') {

                                    contentsData = new manageContents.models.ContentsModel();
                                    contentsData.CONTENT_ID   = templateMapData[contentsAreaId].CONTENT_ID;
                                    contentsData.CONTENT_NM   = templateMapData[contentsAreaId].CONNECTION_NM;
                                    TEMPLATE_CONTENTS_FILE_NM = templateMapData[contentsAreaId].FILE_NM;
                                }
                                else if (templateMapData[contentsAreaId].CONNECTION_TYPE == 'W' || templateMapData[contentsAreaId].CONNECTION_TYPE == 'L') {

                                    // console.log(templateMapData[contentsAreaId].CONNECTION_TYPE);

                                    contentsData = new manageWelMenu.models.WelmenuModel();
                                    contentsData.SEQ       = templateMapData[contentsAreaId].CONTENT_ID;
                                    contentsData.MENU_NM   = templateMapData[contentsAreaId].CONNECTION_NM;

                                    // console.log(contentsAreaId);
                                    // console.log('333', $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="price"]').text());

                                    contentsData.MENU_NM_ENG = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="ename"]').text().trim();
                                    contentsData.MENU_PRICE  = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="price"]').text().trim().replace('\\ ', '');
                                    contentsData.SIDE_DISH   = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="sidedish"]').text().trim().replace('부찬 : ', '');
                                    contentsData.MENU_KCAL   = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="kcal"]').text().trim().replace('칼로리 ', '').replace('Kcal', '');
                                    contentsData.MENU_DT     = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="score1"]').attr('data-menu-dt');
                                    contentsData.MEAL_TYPE   = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="score1"]').attr('data-meal-type');
                                    contentsData.MENU_CODE   = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="score1"]').attr('data-menu-cd');
                                    contentsData.COURSE_TYPE = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="score1"]').attr('data-course');
                                    contentsData.HALL_NO     = $('[data-contents-area-id="' + contentsAreaId + '"][data-product-category="score1"]').attr('data-hall-no');
                                }

                                console.log(contentsData);

                                $('[data-side-id="' + contentsAreaId + '"][data-side-type="' + contentsAreaTypeCode + '"] .connection-contents').empty().append('<li class="info_content"><div>' + templateMapData[contentsAreaId].CONNECTION_NM + '</div><div><img src="../images/common/minus.png" alt="" class="ico_btn" onclick="manageTemplate.unconnectContetns(' + "'" + contentsAreaId + "', " + "'" + contentsAreaTypeCode + "'" + ')"></div></li>');
                            }
                            else {

                                if (contentsAreaType.toUpperCase() == 'PRODUCT') {

                                    for (var i = 0; i < contentsAreaElements.length; i++) {

                                        var productCategory = $(contentsAreaElements[i]).data('product-category').toUpperCase().substring(0, 5);

                                        if (productCategory.toUpperCase() != 'SCORE') {

                                            $(contentsAreaElements[i]).parent().parent().removeClass('active').css('visibility', 'visible');

                                            if (productCategory != 'IMAGE') {
                                                $(contentsAreaElements[i]).html("");
                                            }
                                        }
                                        else {
                                            // 2019-04-24 평가점수 Image
                                            $(contentsAreaElements[i]).parent().parent().removeClass('active').css('visibility', 'visible');
                                        }
                                    }
                                }
                                else {
                                    $(contentsAreaElements[0]).parent().parent().removeClass('active').css('visibility', 'visible');
                                }
                            }

                            // 컨텐츠 영역 정보
                            manageTemplate.contentsAreaInfo[contentsAreaId] = {
                                type                     : contentsAreaType,
                                elements                 : contentsAreaElements,
                                connectionData           : contentsData,
                                connectionType           : connectionType,
                                originConnectionData     : contentsData,
                                originConnectionType     : connectionType,
                                TEMPLATE_CONTENTS_FILE_NM: TEMPLATE_CONTENTS_FILE_NM
                            };

                            // 컨텐츠 영역 이벤트 추가 (TEXT의 경우 달라서 일단 예외 처리)
                            $(this).parent().parent().mouseover(function () { $(contentsAreaElements).parent().parent().addClass('select'); });
                            $(this).parent().parent().mouseout(function () { $(contentsAreaElements).parent().parent().removeClass('select'); });

                            // 컨텐츠 영역 클릭시 해당하는 연결 팝업 호출
                            $(this).parent().parent().click(function () {
                                manageTemplate.showPopup(contentsAreaType.toUpperCase().substring(0, 1), contentsAreaId);
                            });

                            $(this).parent().parent().css('cursor', 'pointer');

                        });
