@model TemplateModel

@{
    ViewBag.Title = "템플릿 관리";
}


@section navi
{
    <div class="current">
        <img src="../images/home.png" alt=""><h1><span> 템플릿 관리 > 템플릿> </span><strong>템플릿 관리</strong></h1>
    </div>
}

<input type="hidden" id="LAYOUT_ID" value="@Model.layoutModel.LAYOUT_ID" />
<input type="hidden" id="TEMPLATE_ID" value="" />

<div class="container_tem">
    <div class="frame_l">
        <div class="info">
            <h1><em class="arrow_ico"></em>레이아웃 정보</h1>
            <table>
                <tr>
                    <td>이름</td>
                    <td id="">@Model.layoutModel.LAYOUT_NM</td>
                </tr>
                <tr>
                    <td>설명</td>
                    <td id="">@Model.layoutModel.LAYOUT_DESC</td>
                </tr>
                <tr>
                    <td>해상도</td>
                    <td id="">@Model.layoutModel.SCREEN_W_H</td>
                </tr>
                <tr>
                    <td>형태</td>
                    <td>@(Model.layoutModel.LAYOUT_HV_TYPE == "H" ? "가로" : "세로") </td>
                </tr>
                <tr>
                    <td>가로x세로</td>
                    <td>@Model.layoutModel.LAYOUT_H_BY_V</td>
                </tr>
            </table>
            <h1><em class="arrow_ico"></em>컨텐츠 영역 정보</h1>
            <select id="selContentsType" class="">
                <option value="">전체</option>
                <option value="P">메뉴</option>
                <option value="B">뱃지</option>
                <option value="H">제목</option>
                <option value="I">이미지</option>
                <option value="M">동영상</option>
                <option value="T">텍스트</option>
                <option value="U">URL</option>
                <option value="D">날짜</option>
            </select>

            @foreach (LayoutDetailModel layoutDetailModel in Model.layoutDetailModels)
            {
                <ul data-side-id="@layoutDetailModel.LAYOUT_SEQ" data-side-type="@layoutDetailModel.CONTENT_TYPE">
                    <li class="info_title">
                        <div>
                            <strong>@layoutDetailModel.CONTENT_TYPE_NM</strong> 영역 (@layoutDetailModel.LAYOUT_SEQ)
                        </div>
                        <div><img src="../images/common/plus.png" alt="" class="ico_btn" onclick="manageTemplate.showPopup('@layoutDetailModel.CONTENT_TYPE', '@layoutDetailModel.LAYOUT_SEQ')"></div>
                    </li>
                    <ul class="connection-contents"></ul>
                </ul>
            }
            <div id="textarea"></div>
        </div>
    </div>
    <div class="frame_r">
        <div class="content">
            <div class="bul_wrap">
                <h3 class="bul_arr f_l">
                    @(ViewBag.type == "U" ? "템플릿 수정" : "템플릿 생성")
                </h3>
                <div class="f_r">

                    @if (ViewBag.type == "U")
                    {
                        <a class="a_btn btn_style2" href="javascript:manageTemplate.popups.showJBTemplate();">수정</a>
                        <a class="a_btn btn_style1" href="javascript:manageTemplate.deleteTemplate('@Model.TEMPLATE_ID');">삭제</a>
                    }
                    else
                    {
                        <a class="a_btn btn_style2" href="javascript:manageTemplate.popups.showJBTemplate();">저장</a>
                    }
                </div>
            </div>
            <div id="templateArea" class="sub_cnt_tem">

                @if (ViewBag.type == "U")
                {
                    { this.GetOutputWriter().Write(File.ReadAllText(Path.Combine(Model.FILE_PATH, Model.FILE_NM))); }
                }
                else
                {
                    { this.GetOutputWriter().Write(File.ReadAllText(Server.MapPath(string.Format("/upload/layout/{0}/{1}", Model.layoutModel.LAYOUT_ID, Model.layoutModel.FILE_NM)))); }
                }
            </div>
        </div>
    </div>
</div>

@* 메뉴 게시 연결 팝업 *@
<div id="gbDisplay1" class="popup1" style="display: none">

    <!-- 게시 메뉴 연결 01 Step -->
    <div class="pop_sc_1">
        <div class="popup_subCnt">
            <div class="bul_wrap">
                <div class="f_r">
                    <a class="a_btn btn_style2" href="javascript:manageWelMenu.searchWelmenu();"><em></em>조회</a>
                </div>
            </div>
            <div class="search_area">
                <label for=""><em></em>게시일</label>
