                // 컨텐츠 영역 표시 부분을 모두 제거하는 함수
                removeContentsAreaWrapper: function () {

                    for (var id in manageTemplate.contentsAreaInfo) {

                        // 연결 정보가 없을 경우 컨텐츠 영역 제거
                        if (!manageTemplate.contentsAreaInfo[id].connectionType) {

                            var contentsAreatype = manageTemplate.contentsAreaInfo[id].type.toUpperCase();
                            var contetnsAreaEle = manageTemplate.contentsAreaInfo[id].elements;


                            // 메뉴 타입의 경우만 요소가 여러개임
                            if (contentsAreatype == 'PRODUCT') {

                                for (var i = 0; i < contetnsAreaEle.length; i++) {

                                    var productCategory = $(contetnsAreaEle[i]).data('product-category').toUpperCase().substring(0, 5);

                                    // 메뉴 타입중 카테고리중 SCORE는 제외
                                    if ($(contetnsAreaEle[i]).data('product-category').toUpperCase().substring(0, 5) != 'SCORE') {
                                        $(contetnsAreaEle[i]).parent().parent().addClass('active').removeClass('select').css('visibility', 'hidden');

