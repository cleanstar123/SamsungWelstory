                            $(elements[0]).append($('<video controls autoplay loop><source src="' + contetnsData.FILE_URL + '"></video>'));
                        }
                        else if (contentsType == 'U' && connectionType == 'C') {
                            $(elements[0]).parent().parent().addClass('active');
                            $(elements[0]).empty();
                            $(elements[0]).append($('<iframe src="' + contetnsData.FILE_URL + (contetnsData.FILE_URL.toUpperCase().indexOf('YOUTUBE') <= 0 ? '' : '?amp;autoplay=1&amp;loop=1') + '" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>'));
                        }
                        else if (contentsType == 'T' && connectionType == 'C') {
                            $(elements[0]).parent().parent().addClass('active');
