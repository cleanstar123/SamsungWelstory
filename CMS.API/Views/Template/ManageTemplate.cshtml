                        $('[data-side-id="' + manageTemplate.contetnsAreaId + '"][data-side-type="' + contentsType + '"] .connection-contents').empty().append('<li class="info_content"><div>' + (contetnsData.MENU_NM || contetnsData.CONTENT_NM || '로컬 파일') + '</div><div><img src="../images/common/minus.png" alt="" class="ico_btn" onclick="manageTemplate.unconnectContetns(' + "'" + manageTemplate.contetnsAreaId + "', " + "'" + contentsType + "'" + ')"></div></li>');

                        manageTemplate.contentsAreaInfo[manageTemplate.contetnsAreaId].connectionData = contetnsData;     // 연결된 컨텐츠 데이터
                        manageTemplate.contentsAreaInfo[manageTemplate.contetnsAreaId].connectionType = connectionType;   // 컨텐츠 연결 방식(W : 메뉴게시, C : 컨텐츠, L: 로컬)
                    }
                    catch (e) {
                        alert('컨텐츠 연결중 오류가 발생하였습니다,\n 에러 메세지 : ' + e.message);
