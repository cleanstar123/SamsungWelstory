                    finally {
                        manageWelMenu.popups.jbWelMenu.close();
                        manageContents.popups.jbContents.close();
                    }
                },
                // 템플릿 저장
                saveTemplate: function (actionType) {

                    if (!manageTemplate.elements.$M_TEMPLATE_NM.val()) {
                        alert('템플릿 이름을 입력하세요.');
                        manageTemplate.elements.$M_TEMPLATE_NM.focus();
                        return;
                    }

                    // 01. 컨텐츠와 연결되지 않은 영역 제거
                    manageTemplate.removeContentsAreaWrapper();

                    //console.log($('#templateArea').html());

                    // 생성일 경우만 스크립트 추가
                    // 수정일 경우는 이미 스크립트가 추가 되어 있음.
                    if ("@ViewBag.type" == 'I') {
                        // 02. 메뉴 평가 레이아웃일 경우 해당 스크립트 삽입
                        // var path = location.protocol + '//' + location.hostname + (location.port ? ':' + location.port : '');
                        // var path = '{TEMPLATE_PATH}';
                        var pathjquery = /*path +*/ '/Scripts/' + 'jquery-3.3.1.min.js';
                        var pathjs     = /*path +*/ '/Scripts/' + 'loadscript.js';

                        var s = document.createElement("script");
                        s.type = "text/javascript";
                        s.src = pathjquery;

                        $("#layer").append(s);

                        s = document.createElement("script");
                        s.type = "text/javascript";
                        s.src = pathjs;

                        $("#layer").append(s);
                    }

                    // 03. 이미지 URL 재정의 (같은 경로에 이미지 파일을 저장할 계획)
                    $('#templateArea *').each(function () {

                        var url = $(this).css('background-image');

                        if (url != 'none' && url.indexOf('upload/template') < 0) {

                            var names = $(this).css('background-image').split('/');
                            var name  = names[names.length - 1].replace('")', "");

                            $(this).css('background-image', "url('{TEMPLATE_PATH}/" + name + "')");
                        }

                    });


                    $('#layer img').each(function () {

                        var url = $(this).attr('src');

                        // 컨텐츠 연결 방식이 W, L 일 경우 이미지 주소를 변경하지 않음
                        // 컨텐츠 연결 방식이 C일 경우 이미지 주소를 변경

                        if (url.indexOf('upload/contents') >= 0) {
                            var fileName = url.substring(url.lastIndexOf('/') + 1);
                            $(this).attr('src', '{TEMPLATE_PATH}/' + fileName);
                        }
                    });

                    // 04. 레이어 디스플레이 none 처리
                    $('#layer').css('display', 'none');

                    // 05. 템플릿 HTML 저장

                    var templateModel = new manageTemplate.models.TemplateModel();

                    templateModel.TEMPLATE_NM   = manageTemplate.elements.$M_TEMPLATE_NM.val();
                    templateModel.TEMPLATE_DESC = manageTemplate.elements.$M_TEMPLATE_DESC.val();
                    templateModel.TEMPLATE_HTML = $('#templateArea').html();

                    var templateMapModels = [];

                    for (var id in manageTemplate.contentsAreaInfo) {

                        if (manageTemplate.contentsAreaInfo[id].connectionType) {

                            var templateMapModel = new manageTemplate.models.TemplateMapModel();

                            templateMapModel.LAYOUT_SEQ      = id;
                            templateMapModel.CONNECTION_TYPE = manageTemplate.contentsAreaInfo[id].connectionType;

                            // 메뉴 게시 연결일 경우
                            if (manageTemplate.contentsAreaInfo[id].connectionType == 'W') {
                                templateMapModel.CONTENT_ID        = manageTemplate.contentsAreaInfo[id].connectionData.SEQ;
                                templateMapModel.CONNECTION_NM     = manageTemplate.contentsAreaInfo[id].connectionData.MENU_NM;
                            }
                            else if (manageTemplate.contentsAreaInfo[id].connectionType == 'C') {
                                templateMapModel.CONTENT_ID        = manageTemplate.contentsAreaInfo[id].connectionData.CONTENT_ID;       // 연결된 컨텐츠 아이디
                                templateMapModel.CONTENT_TYPE      = manageTemplate.contentsAreaInfo[id].connectionData.CONTENT_TYPE;     // 연결된 컨텐츠 타입
                                templateMapModel.CONNECTION_NM     = manageTemplate.contentsAreaInfo[id].connectionData.CONTENT_NM;       // 연결된 컨텐츠 이름
                                templateMapModel.CONTENT_FILE_PATH = manageTemplate.contentsAreaInfo[id].connectionData.FILE_PATH;        // 연결된 컨텐츠 파일 경로
                                templateMapModel.CONTENT_FILE_NM   = manageTemplate.contentsAreaInfo[id].connectionData.FILE_NM;          // 연결된 컨텐츠 파일 이름
                                templateMapModel.FILE_NM           = manageTemplate.contentsAreaInfo[id].TEMPLATE_CONTENTS_FILE_NM;       // 템플릿과 연결되어 저장된 경로

                                if (manageTemplate.contentsAreaInfo[id].originConnectionType && manageTemplate.contentsAreaInfo[id].originConnectionData) {
                                    if (manageTemplate.contentsAreaInfo[id].originConnectionType == manageTemplate.contentsAreaInfo[id].connectionType &&
                                        manageTemplate.contentsAreaInfo[id].originConnectionData.CONTENT_ID == manageTemplate.contentsAreaInfo[id].connectionData.CONTENT_ID) {

                                        templateMapModel.IS_UPDATE = false;
                                    }
                                }
                            }
                            else if (manageTemplate.contentsAreaInfo[id].connectionType == 'L') {
                                templateMapModel.CONTENT_ID        = manageTemplate.contentsAreaInfo[id].connectionData.SEQ;
                                templateMapModel.CONNECTION_NM     = manageTemplate.contentsAreaInfo[id].connectionData.MENU_NM;
                            }

                            templateMapModels.push(templateMapModel);
                        }
                    }

                    //console.log(templateMapModels);
                    //return;

                    manageTemplate.popups.jbTemplate.close();

                    var formData = new FormData();
                    formData.append('TYPE', actionType);
                    formData.append('templateModel', JSON.stringify(templateModel));
                    formData.append('templateMapModels', JSON.stringify(templateMapModels));

                    simplefileUploadAjax('@Url.Action("uploadfile", "template")', formData).done(function (data) {

                        var data = JSON.parse(data);

                        if (data.ERR_CODE == "0") {
                            resultMessage(actionType, function () {

                                if (localStorage && localStorage.getItem('scheduleId')) {
                                    location.href = '@Url.Action("index", "Schedule")';
                                }
                                else {
                                    location.href = '@Url.Action("index", "template")';
                                }

                            });
                        }
                        else {
                            if (data.ERROR_MSG) {
                                alert(data.ERROR_MSG);
                                if (data.ERR_CODE == "9998") {
                                    location.href = '@Url.Action("logout", "account")';
                                    return;
                                }
                            }
                            else
                                alert('오류가 발생하였습니다.');

                            location.reload();
                        }
                    });

                    @*simpleAjax('@Url.Action("saveTemplate", "template")', { TYPE: actionType, templateModel: templateModel, templateMapModels: templateMapModels }).done(function (data) {

                        if (data.ERR_CODE == "0") {
                            resultMessage(actionType, function () {
                                location.href = '@Url.Action("index", "template")';
                            });
                        }
                        else {
                            if (data.ERROR_MSG)
                                alert(data.ERROR_MSG);
                            else
                                alert('오류가 발생하였습니다.');

                            location.reload();
                        }
                    });*@
                },
                deleteTemplate: function (id) {

                    if (!confirm(deleteConfirmMessage))
                        return;

                    var templateModel = new manageTemplate.models.TemplateModel();

                    simpleAjax('@Url.Action("DeleteTemplate", "template")', { templateModel: templateModel }).done(function (data) {

