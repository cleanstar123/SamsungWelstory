                    manageWelMenu.elements.$M_MENU_NM.val('');
                    manageWelMenu.elements.$M_MENU_NM_ENG.val('');
                    manageWelMenu.elements.$M_MENU_PRICE.val('');
                    manageWelMenu.elements.$M_SIDE_DISH.val('');
                    manageWelMenu.elements.$M_MENU_KCAL.val('');

                    $('#localfile').val('');

                    connectionType = 'W';

                    var d = new Date();
                    var hour = d.getHours();
                    var minute = d.getMinutes();

                    // 05 ~ 09 : 조식
                    // 09 ~ 15 : 중식
                    // 15 ~ 20 : 석식
                    // 야식

                    // 조식
                    if ((hour >= 5 && hour <= 8)) {
                        manageWelMenu.elements.$MEAL_TYPE.val('1');
                    }
                    // 중식
                    else if (hour >= 9 && hour <= 14) {
                        manageWelMenu.elements.$MEAL_TYPE.val('2');
                    }
                    // 석식
                    else if (hour >= 15 && hour <= 19) {
                        manageWelMenu.elements.$MEAL_TYPE.val('3');
