        function previewFile() {

            var preview = document.querySelector('img[id=M_PHOTO_CD]');
            var file    = document.querySelector('input[id=localfile]').files[0];
            var reader = new FileReader();

            reader.addEventListener("load", function () {

                preview.src = reader.result;

                var canvas = document.getElementById('localImageCanvas');
                var ctx    = canvas.getContext('2d');

                var image = new Image();

                image.onload = function () {

                    canvas.width  = image.width;
                    canvas.height = image.height;

                    ctx.drawImage(image, 0, 0);

                    if (image.width > 668 || image.height > 458) {

                        var per = 1;
                        var reviseWidth = 0;
                        var reviseHeight = 0;

                        if (preview.width > preview.height) {
                            per = 668 / image.width;
                        }
                        else {
                            per = 458 / image.height;
                        }

                        reviseWidth  = image.width  * per;
                        reviseHeight = image.height * per;

                        tempCanvas = resample_single(canvas, reviseWidth, reviseHeight, true);

                        preview.src = tempCanvas.toDataURL(document.querySelector('input[id=localfile]').files[0].type, 1.0);
                    }
                }

                image.src = preview.src;

            }, false);

            if (file && file.type.indexOf('image') >= 0) {
                reader.readAsDataURL(file);
            }
            //else {
            //    alert('이미지 파일을 선택하세요.');
            //    $('#localfile').val('');
            //    return;
            //}
        }

