                                        break;
                                    case 'SCORE1':
                                    case 'SCORE2':
                                    case 'SCORE3':
                                    case 'SCORE4':
                                    case 'SCORE5':
                                        // 2019-04-24 평가점수 Image
                                        $(elements[i]).parent().parent().addClass('active');
                                        $(elements[i]).parent().parent().css('visibility', 'visible');

                                        $(elements[i]).attr('data-restaurant-code', '@ViewBag.RESTAURANT_CD');
                                        $(elements[i]).attr('data-menu-dt',   contetnsData.MENU_DT);
                                        $(elements[i]).attr('data-meal-type', contetnsData.MEAL_TYPE);
                                        $(elements[i]).attr('data-menu-cd',   contetnsData.MENU_CODE);
                                        $(elements[i]).attr('data-course',    contetnsData.COURSE_TYPE);
                                        $(elements[i]).attr('data-hall-no',   contetnsData.HALL_NO);
                                        break;
                                }
                            }
