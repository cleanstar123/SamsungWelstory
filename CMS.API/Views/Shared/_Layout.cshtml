    <link href="~/Content/font-awesome.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/common.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/jBox.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />*@
    
    @Styles.Render("~/Content/css")

    @RenderSection("styles", false)
</head>
<body>
    <input type="hidden" id="RESTAURANT_CD" value="@ViewBag.RESTAURANT_CD" />
    <div id="wrap">
        <div class="top">
            <div>
                <h1 class="logo"><a href="javascript:void(0);"><img src="../images/logo.png" alt="삼성웰스토리 CMS 로고"></a></h1>
                <ul class="log">
                    <li><img src="../images/user.png" alt="사용자 아이콘"><span>@ViewBag.USER_NM (@ViewBag.RESTAURANT_NM)</span>님 환영합니다</li>
                    <li><a href="@Url.Action("logout", "account")">로그아웃</a></li>
                </ul>
            </div>
        </div>
        <header class="header">
            <nav class="nav_a">
                <div class="gnb_wrap">
                    <div class="gnb gnb_w">
                        <ul class="snb_level1">
                            <li class="m01">
                                <a href="javascript:void(0);">템플릿 관리</a>
                                <ul class="snb_level2">
                                    <li><a href="@Url.Action("index", "contents")">컨텐츠</a></li>
                                    <li><a href="@Url.Action("index", "template")">템플릿</a></li>
                                    <li><a href="@Url.Action("index", "layout")">레이아웃</a></li>
                                </ul>
                            </li>
                            <li class="m02">
                                <a href="javascript:void(0);">스케줄링</a>
                                <ul class="snb_level2">
                                    <li><a href="@Url.Action("index", "schedule")">스케줄</a></li>
                                </ul>
                            </li>
                            <li class="m03">
                                <a href="javascript:void(0);">리포트</a>
                                <ul class="snb_level2">
                                    <li><a href="javascript:alert('서비스 준비중입니다.');">고객만족</a></li>
                                    @if ((ViewBag.RESTAURANT_CD == "REST000196") && (ViewBag.USER_ROLE == "10001"))
                                    {
                                        <li><a href="@Url.Action("reportcongestion", "report")">혼잡도 리포트</a></li>
                                    }
                                    </ul>
                            </li>
                            <li class="m04">
                                <a href="javascript:void(0);">시스템관리</a>
                                <ul class="snb_level2">
                                    <li><a href="@Url.Action("index", "display")">디스플레이 관리</a></li>
                                    <li><a href="@Url.Action("displaygroup", "display")">디스플레이 그룹 관리</a></li>

                                    @if (ViewBag.USER_ROLE == "10001")
                                    {
                                        <li><a href="@Url.Action("index", "code")">코드 관리</a></li>
                                        <li><a href="@Url.Action("index", "user")">사용자 관리</a></li>

                                        if (ViewBag.RESTAURANT_CD == "REST000196")
                                        {
                                            <li><a href="@Url.Action("sensormanagement", "sensor")">혼잡도 센서 관리</a></li>
                                        }
                                    }
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            <div class="line"></div>
        </header>

        @RenderSection("navi", false)


        @RenderBody()

        <!-- 로딩바 -->
        <div id="loadingbar" class="loading">
            <img src="~/images/loading_bg_black.gif" alt="">
        </div>
        <!--// 로딩바 -->
        @* URL 정의 *@
        <script>
            // 컨텐츠 관련 URL 정의
            var urlContentsList         = '@Url.Action("list",         "contents")';
            var urlContentsUploadText   = '@Url.Action("uploadtext",   "contents")';
            var urlContentsUploadUrl    = '@Url.Action("uploadurl",    "contents")';
            var urlContentsUploadFile   = '@Url.Action("uploadfile",   "contents")';
            var urlContentsDelete       = '@Url.Action("manageDelete", "contents")';

            // 디스플레이 관련 URL 정의
            var urlDisplayGroup         = '@Url.Action("DisplayGroups", "display")';
            var urlDisplayMap           = '@Url.Action("DisplayMaps", "display")';

            // 스케줄 관련 URL 정의
            var urlManageSchedule       = '@Url.Action("ManageSchedule", "Schedule")';
            var urlCheckScheduleOverlap = '@Url.Action("CheckScheduleOverlap", "Schedule")';
        </script>

        @*<script src="https://cdn.jsdelivr.net/gh/StephanWagner/jBox@v0.4.9/Source/jBox.min.js"></script>*@
        @*<script src="http://netdna.bootstrapcdn.com/bootstrap/3.3.5/js/bootstrap.js"></script>*@

        @*<script src="~/Scripts/jquery-3.3.1.min.js"></script>
        <!-- jqgrid -->
        <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
        <script src="~/Scripts/grid.locale-en.js"></script>
        <script src="~/Scripts/jquery.jqGrid.min.js"></script>

        <!-- jbox -->
        <script src="~/Scripts/jBox.min.js"></script>
        <script src="~/Scripts/jquery-ias.min.js"></script>
        <!-- 위지윅 -->
        <script src="~/Scripts/bootstrap.js"></script>
        <!-- 입력제한 -->
        <script src="~/Scripts/cleave.min.js"></script>

        <script src="~/Scripts/datepicker.js"></script>       <!-- 퍼블리셔 js -->
        <script src="~/Scripts/datepicker-ko.js"></script>
        <script src="~/Scripts/common.js"></script>           <!-- 퍼블리셔 js -->
        <script src="~/Scripts/cms-common.js"></script>       <!-- 개발자   js -->*@

        @Scripts.Render("~/bundles")

        @RenderSection("scripts", false)


        <!-- 비밀번호가 초기값일 경우 변경 -->

        @if (ViewBag.CHANGE_PASS_YN == "Y")
        {

            <div id="jbUserPassChange" class="popup15">
                <div class="popup_area">
                    <div class="popup_contents">
                        <table>
                            <tr>
                                <td>비밀번호</td>
                                <td><input type=password id="CHANGE_PASS" maxlength="15"></td>
                            </tr>
                            <tr>
                                <td>비밀번호 확인</td>
                                <td><input type=password id="CONFIRM_PASS" onkeyup="enterKey()" maxlength="15"></td>
                            </tr>
                        </table>
                    </div>
                    <div class="step_button">
                        <a class="a_btn btn_style3" href="javascript:manageUser();">확인</a>
                        <a class="a_btn btn_style3" href="javascript:closeJBUserPassChange();">취소</a>
                    </div>
                </div>
            </div>

            <script>
                var jbUserPassChange = new jBox('Modal', {
                    draggable: 'title',
                    dragOver: false,
                    closeOnEsc: true,
                    isolateScroll: false,
                    attach: '#myModal',
                    title: '비밀번호 변경',
                    content: $('#jbUserPassChange'),
                    closeButton: 'title',
                    width: "15%",
                    height: "13%",
                    minWidth: 130,
                    minHeight: 100,
                    responsiveMinWidth: 130,
                    responsiveMinHeight: 100,
                    responsiveWidth: false,
                    responsiveHeight: false
                });

                function closeJBUserPassChange() {
                    jbUserPassChange.close();
                }

                $('#CHANGE_PASS').focus();
                jbUserPassChange.open();

                function enterKey() {
                    if (window.event.keyCode == 13) {

                        manageUser();
                    }
                }

                function manageUser() {
                    if ($('#CHANGE_PASS').val() != $('#CONFIRM_PASS').val()) {

                        alert('비밀번호가 다릅니다.');
                        $('#CHANGE_PASS').focus();
                        return false;
                    }

                    if ($('#CHANGE_PASS').val() != $('#CONFIRM_PASS').val()) {

                        alert('비밀번호가 다릅니다.');
                        $('#CHANGE_PASS').focus();
                        return false;
                    }

                    if ($('#CHANGE_PASS').val() == '1111') {
                        alert('기본 비밀번호는 변경할 수 없습니다.');
                        return false;
                    }

                    simpleAjax('@Url.Action("ManageUser", "user")', { TYPE: 'U', userModel: { USER_ID: '@ViewBag.USER_ID', USER_PW: $('#CONFIRM_PASS').val(), USER_NM: '@ViewBag.USER_NM', RESTAURANT_CODE: '@ViewBag.RESTAURANT_CD', GROUP_CD: '@ViewBag.USER_ROLE', USE_YN: '@ViewBag.CHANGE_PASS_YN' } }).done(function (data) {

                        console.log(data);

                        if (data.ERR_CODE == '0') {
                            alert('비밀번호가 변경 되었습니다.\n로그인 화면으로 이동합니다.');
                            window.location.href = '@Url.Action("logout", "account")';
                        }
                        else {
                            alert('비밀번호 변경중 오류가 발생하였습니다.\n로그인 화면으로 이동합니다.');
                            window.location.href = '@Url.Action("logout", "account")';
                        }

                    });
                }
            </script>
        }

        <!--// 비밀번호가 초기값일 경우 변경 -->

    </div>
    <!--// Wrap -->
</body>
</html>