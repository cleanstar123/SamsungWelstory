
@{
    ViewBag.Title = "레이아웃";
}

@section navi
{
    <div class="current">
        <img src="../images/home.png" alt=""><h1><span>템플릿 관리 > </span><strong>레이아웃</strong></h1>
    </div>
}

<input type="hidden" id="mhidLayoutId" /> <!-- 팝업창에서 사용하는 레이아웃 아이디 -->


<div class="container_wrap">
    <div class="content">
        <div class="bul_wrap">
            <h3 class="bul_arr f_l">레이아웃</h3>
            <div class="f_r">
                <a class="a_btn btn_style1" href="javascript:currentPageNo = 1; searchLayout();"><em></em>조회</a>
                @if (ViewBag.USER_ROLE == "10001")
                {
                <a class="a_btn btn_style2" href="javascript:showJBLayoutUpload('I');">레이아웃 업로드</a>
                }
                <a class="a_btn btn_style2" href="javascript:manageTemplate();">템플릿 생성</a>
                @if (ViewBag.USER_ROLE == "10001")
                {
                <a class="a_btn btn_style1" href="javascript:manageLayout('D');">삭제</a>
                }
            </div>
        </div>

        <div class="search_area">
            <label for=""><em></em>레이아웃명</label>
            <input type="text" id="txtLayoutNm" />
        </div>

        <h3 class="bul_arr2"><p class="f_l">레이아웃 리스트</p><span class="f_r" id="pagingInfoArea"></span></h3>
        <div class="tem_sub_cnt">
            <ul id="layoutArea" class="tem_list"></ul>
        </div>

    </div>
</div>

<!-- 모달 창 -->

<div id="jbLayout" class="popup4" style="display:none;">
    <div class="popup_area">
        <div class="popup_contents">
            <table>
                <tr>
                    <td>레이아웃 이름</td>
                    <td><input type="text" id="mtxtLayoutNm" maxlength="60"></td>
                </tr>
                <tr>
                    <td>레이아웃 설명</td>
                    <td><input type="text" id="mtxtLayoutDesc" onchange="layoutUploadChange();" maxlength="60"></td>
                </tr>
                <tr>
                    <td>레이아웃 파일</td>
                    <td><input type="file" id="mfileLayoutFileNm" class="w_m w_m_n" onchange="layoutUploadChange();"></td>
                </tr>
                <tr>
                    <td>고정 이미지 파일</td>
                    <td><input type="file" id="mfileImageFileNm" class="w_m w_m_n" @*onchange="ImageUploadChange();"*@ multiple></td>
                </tr>
                <tr>
                    <td>해상도 넓이</td>
                    <td><input type="text" id="mtxtScreenW"></td>
                </tr>
                <tr>
                    <td>해상도 높이</td>
                    <td><input type="text" id="mtxtScreenH"></td>
                </tr>
                <tr>
                    <td>유형</td>
                    <td><input type="text" id="mtxtLayoutHVType" disabled></td>
                </tr>
                <tr>
                    <td>가로 X 세로</td>
                    <td><input type="text" id="mtxtLayoutHByV" disabled></td>
                </tr>
                <tr>
                    <td>컨텐츠 영역</td>
                    <td><input type="text" id="mtxContentsCnt" disabled></td>
                </tr>
                <tr>
                    <td>평가 유무</td>
                    <td><input type="text" id="mtxtEvalUseYn" disabled></td>
                </tr>
            </table>
            <p><span>레이아웃 수정은할 수 없습니다. (삭제하고 다시 등록해주세요.)</span></p>
        </div>
        <div class="step_button">
            <a class="a_btn btn_style3" href="javascript:manageLayout('I');">저장</a>
            <a class="a_btn btn_style3" href="javascript:jbLayout.close(); void 0">취소</a>
        </div>
    </div>
</div>

@*업로드 레이아웃 페이지*@
<div id="uploadLayoutArea" style="display:none;"></div>

@section scripts
{
    <script src="~/Scripts/cmslayout.js"></script>
    <script>
        /*********************************/
        /* 변수 선언 및 클래스 정의 시작 */

        function LayoutModel() {
            this.RESTAURANT_CODE = '@ViewBag.RESTAURANT_CD';
            this.LAYOUT_ID       = '';
            this.LAYOUT_TYPE     = 'UPL';   // 현재는 업로드만 구현되어 있으므로 고정 값
            this.LAYOUT_NM       = '';
            this.LAYOUT_DESC     = '';
            this.FILE_NM         = '';
            this.CONTENT_CNT     = '';
            this.SCREEN_W        = '';
            this.SCREEN_H        = '';
            this.LAYOUT_HV_TYPE  = '';
            this.LAYOUT_H_BY_V   = '';
            this.EVAL_USE_YN     = '';
            this.PAGE_CNT        = '8';
            this.PAGE_NO         = '';
        };

        function LayoutDetailModel() {
            this.LAYOUT_SEQ  = '';
            this.CONTENT_TYPE = '';
        }

        /* 변수 선언 및 클래스 정의 끝   */
        /*********************************/

        /*********************************/
        /***** jquery 요소 정의 시작 *****/

        var $hidActionType = $('#hidActionType');

        // 팝업
        var $dialogFormLayoutUpload = $("#dialog-form-layout-upload");

        var $layoutArea        = $('#layoutArea');
        var $mhidLayoutId      = $('#mhidLayoutId');
        var $mtxtLayoutNm      = $('#mtxtLayoutNm');
        var $mtxtLayoutDesc    = $('#mtxtLayoutDesc');
        var $mfileLayoutFileNm = $('#mfileLayoutFileNm');
        var $mfileImageFileNm  = $('#mfileImageFileNm');
        var $mtxtScreenW       = $('#mtxtScreenW');
        var $mtxtScreenH       = $('#mtxtScreenH');
        var $mtxContentsCnt    = $('#mtxContentsCnt');
        var $mtxtLayoutHVType  = $('#mtxtLayoutHVType');
        var $mtxtLayoutHByV    = $('#mtxtLayoutHByV');
        var $mtxtEvalUseYn     = $('#mtxtEvalUseYn');

        // 검색 조건
        var $txtLayoutNm       = $('#txtLayoutNm');

        // 영역
        var $pagingInfoArea    = $('#pagingInfoArea');


        /****** jquery 요소 정의 끝 ******/
        /*********************************/

        /*********************************/
        /***** 초기화 함수 정의 시작 *****/

        function initLayoutModal() {
            $hidActionType.val('');
            $mhidLayoutId.val('');
            $mtxtLayoutNm.val('');
            $mtxtLayoutDesc.val('');
            $mfileLayoutFileNm.val('');
            $mfileImageFileNm.val('');
            $mtxtScreenW.val('');
            $mtxtScreenH.val('');
            $mtxContentsCnt.val('');
            $mtxtLayoutHVType.val('');
            $mtxtLayoutHByV.val('');
            $mtxtEvalUseYn.val('');
        }

        /****** 초기화 함수 정의 끝 ******/
        /*********************************/


        /*********************************/
        /******* 팝업 창 정의 시작 *******/


        var jbLayout = new jBox('Modal', {
            draggable          : 'title',
            dragOver           : false,
            closeOnEsc         : true,
            attach             : '#myModal',
            title              : '레이아웃 업로드',
            content            : $('#jbLayout'),
            closeButton        : 'title',
            width              : "25%",
            height             : "40%",
            minWidth           : 550,
            minHeight          : 380,
            repositionOnOpen   : false,
            repositionOnContent: false,
            isolateScroll      : false,
            responsiveMinWidth : 550,
            responsiveMinHeight: 380,
            responsiveWidth    : false,
            responsiveHeight   : false
        });

        // 스케줄 등록 팝업 열기
        function showJBLayoutUpload(actionType) {

            // 창 초기화
            initLayoutModal();
            jbLayout.open();
        }

        /******* 팝업 창 정의 끝 *********/
        /*********************************/


        /*********************************/
        /****** CRUD 함수 정의 시작 ******/

        var currentPageNo      = 0;
        var totalPageCnt       = 0;
        var layoutData         = {};
        var layoutSelectedId   = '';

        // 레이아웃 조회
        function searchLayout() {

            var layoutModel = new LayoutModel();
            layoutModel.LAYOUT_NM = $txtLayoutNm.val();
            layoutModel.PAGE_NO = currentPageNo;

            simpleAjax('@Url.Action("getLayoutPageList", "layout")', { layoutModel: layoutModel }, true, (currentPageNo == 1 ? false : true)).done(function (data) {
                // 2019-05-14 레이아웃 조회 데이터 변조 체크
                if (data.ERROR_MSG != null) {
                    alert(data.ERROR_MSG);

                    if (data.ERR_CODE == "9998")
                        window.location.href = '@Url.Action("logout", "account")';
                }
                else {

                    var layout = '';

                    // 페이지 1 조회시 내용 초기화
                    if (currentPageNo == 1) {
                        $layoutArea.parent().scrollTop(0);
                        $layoutArea.empty();
                        $('#nodata').remove();
                        layoutData = {};

                        if (data.Table.length <= 0) {
                            layout += '<p id="nodata" class="date_n">데이터가 없습니다.</p>';
                            $layoutArea.empty();
                            $layoutArea.parent().append($(layout));

                            $pagingInfoArea.empty().text(0 + '/' + 0 + ' Page (' + 0 + ' 건)');

                            return;
                        }
                    }


                    for (var i = 0; i < data.Table.length; i++) {
                        layout += '<li class="transition">';
                        layout += '<h1>';
                        layout += '<div class="f_l"><label class="list_title" for="' + data.Table[i].LAYOUT_ID + '">';
                        layout += '<input type="checkbox" id="' + data.Table[i].LAYOUT_ID + '" name="layout" />';
                        layout += '<p>' + data.Table[i].LAYOUT_ID + '<strong>' + data.Table[i].LAYOUT_NM + '</strong></p>';
                        layout += '</label></div>';
                        layout += '<div class="f_r"><i class="fa fa-pen"></i>';
                        //layout += '<img src="../images/common/write_ico.png" onmouseover="this.src=' + "'../images/common/write_ico_over.png'" + ';" onmouseout="this.src=' + "'../images/common/write_ico.png'" + ';" class="ico_btn" onclick="showJBLayoutUpload(' + "'U'," + "'" + data.Table[i].LAYOUT_ID + "'" + ')">';
                        layout += '</div>'
                        layout += '</h1>';
                        layout += '<div class="thumbnail_style1">';
                        layout += '<img  src="' + data.Table[i].THUMBNAIL_NM + '" />';
                        layout += '</div >';
                        layout += '<table>';
                        layout += '<tr><td>레이아웃 설명</td><td>' + data.Table[i].LAYOUT_DESC + '</td></tr>';
                        layout += '<tr><td>해상도</td><td>' + data.Table[i].SCREEN_W_H + '</td></tr>';
                        layout += '</table>';
                        layout += '</div>';
                        layout += '</li>';

                        layoutData[data.Table[i].LAYOUT_ID] = data.Table[i];
                    }

                    var $layout = $(layout);

                    $layout.find('img').on('error', function () {
                        $(this).parent('div').empty().append('<div class="thumbnail_style1"><img src="/images/sub/icon_layout.png" alt=""></div>');
                    });

                    $layoutArea.append($layout);
                    totalPageCnt = data.Table1[0].TOT_PAGE_COUNT;  // 총 페이지 수
                    $pagingInfoArea.empty().text(currentPageNo + '/' + data.Table1[0].TOT_PAGE_COUNT + ' Page (' + data.Table1[0].TOT_ROW_COUNT + ' 건)');

                    $('input[type="checkbox"][name="layout"]').click(function () {
                        if ($(this).prop('checked')) {

                            $('input[type="checkbox"][name="layout"]').prop('checked', false).parents('.transition').removeClass('list_click');
                            $(this).prop('checked', true).parents('.transition').addClass('list_click');

                            layoutSelectedId = $(this).attr('id');
                        }
                        else {
                            $(this).parents('.transition').removeClass('list_click');
                            layoutSelectedId = '';
                        }
                    });
                }
            });
        }

        // 레이아웃 저장/수정/삭제
        function manageLayout(type, rowId) {

            // 정합성 체크
            if (type.toUpperCase() == "I") {

                if (!$mtxtLayoutNm.val()) {
                    alert('레이아웃 이름을 입력하세요.');
                    $mtxtLayoutNm.focus();
                    return false;
                }

                if ($mfileLayoutFileNm.get(0).files.length <= 0) {
                    alert('업로드할 레이아웃이 없습니다.');
                    $mfileLayoutFileNm.focus();
                    return false;
                }

                if (!$mtxtScreenW.val()) {
                    alert('해상도 넓이를 입력하세요.');
                    $mtxtScreenW.focus();
                    return false;
                }

                if (!$mtxtScreenH.val()) {
                    alert('해상도 높이를 입력하세요.');
                    $mtxtScreenH.focus();
                    return false;
                }

                if (contentsAreaInfo.layoutHVType.length != 1) {
                    alert('디스플레이 형태가 잘 못 되었습니다. 레이아웃을 확인하세요.');
                    return false;
                }
            }
            else if (type.toUpperCase() == "D") {

                if (!layoutSelectedId) {
                    alert('레이아웃을 선택하세요.');
                    return false;
                }

                if (!confirm(deleteConfirmMessage))
                    return;
            }

            var formData = new FormData();

            // 레이아웃 저장
            if (type.toUpperCase() == "I") {

                var fileUpload = $mfileLayoutFileNm.get(0);
                var files = fileUpload.files;

                for (var i = 0; i < files.length; i++) {
                    formData.append(files[i].name, files[i]);
                }

                var imageUpload = $mfileImageFileNm.get(0);
                var images = imageUpload.files;

                for (var i = 0; i < images.length; i++) {
                    formData.append(images[i].name, images[i]);
                }


                // 레이아웃 마스터
                var layoutModel = new LayoutModel();

                layoutModel.LAYOUT_ID = '';
                layoutModel.LAYOUT_NM = $mtxtLayoutNm.val();
                layoutModel.LAYOUT_DESC = $mtxtLayoutDesc.val();
                layoutModel.CONTENT_CNT = $mtxContentsCnt.val();
                layoutModel.SCREEN_W = $mtxtScreenW.val();
                layoutModel.SCREEN_H = $mtxtScreenH.val();
                layoutModel.LAYOUT_HV_TYPE = contentsAreaInfo.layoutHVType;
                layoutModel.LAYOUT_H_BY_V = $mtxtLayoutHByV.val();
                layoutModel.EVAL_USE_YN = $mtxtEvalUseYn.val();

                formData.append('layoutModel', JSON.stringify(layoutModel));

                // 레이아웃 상세
                var layoutDetailModels = [];

                for (var contentstype in contentsAreaInfo.CONTENTSTYPES) {

                    for (var i = 0; i < contentsAreaInfo.CONTENTSTYPES[contentstype].length; i++) {

                        var layoutDetailModel = new LayoutDetailModel();
                        layoutDetailModel.CONTENT_TYPE = contentstype.toUpperCase().substring(0, 1);

                        if (typeof contentsAreaInfo.CONTENTSTYPES[contentstype][i] === 'object')
                            layoutDetailModel.LAYOUT_SEQ = contentsAreaInfo.CONTENTSTYPES[contentstype][i].contentsAreaId;
                        else
                            layoutDetailModel.LAYOUT_SEQ = contentsAreaInfo.CONTENTSTYPES[contentstype][i];

                        layoutDetailModels.push(layoutDetailModel);
                    }
                }

                formData.append('layoutDetailModels', JSON.stringify(layoutDetailModels));

                simplefileUploadAjax('@Url.Action("layoutupload", "layout")', formData).done(function (data) {

                    var dataObj = JSON.parse(data);

                    if (dataObj.ERR_CODE == "0") {
                        resultMessage(type, searchLayout);
                    }
                    else {
                        alert(dataObj.ERROR_MSG);

                        if (dataObj.ERR_CODE == "9998") {
                            window.location.href = '@Url.Action("logout", "account")';
                            return;
                        }
                    }

                    jbLayout.close();
                });
            }
            else if (type.toUpperCase() == "D") {

                var data = {
                    TYPE: type,
                    layoutModel: {}
                };

                var layoutModel = new LayoutModel();
                layoutModel.LAYOUT_ID = layoutSelectedId;

                data.layoutModel = layoutModel;

                simpleAjax('@Url.Action("layoutmanage", "layout")', data).done(function (data) {

                    if (data.ERR_CODE == "0") {
                        resultMessage(type, searchLayout);
                    }
                    else
                        alert(data.ERROR_MSG);

                    if (data.ERR_CODE == "9998")
                        window.location.href = '@Url.Action("logout", "account")';
                });
            }
        }

        /******* CRUD 함수 정의 끝 *******/
        /*********************************/

        function layoutUploadChange() {
            readLayoutFile('mfileLayoutFileNm', 'uploadLayoutArea', layoutBindCallBack);
        }

        function layoutBindCallBack() {
            $mtxtScreenW.val(contentsAreaInfo.screenW);
            $mtxtScreenH.val(contentsAreaInfo.screenH);
            $mtxContentsCnt.val(contentsAreaInfo.contentsCnt);
            $mtxtLayoutHVType.val(contentsAreaInfo.layoutHVType == 'H' ? '가로' : '세로');
            $mtxtLayoutHByV.val(contentsAreaInfo.layoutHByV);
            $mtxtEvalUseYn.val(contentsAreaInfo.evalUseYn);
        }

        function manageTemplate() {

            if (!layoutSelectedId) {
                alert('템플릿 생성에 사용할 레이아웃을 선택하세요.');
                return false;
            }

            window.location.href = '@Url.Action("managetemplate", "template")' + '?type=I&id=' + layoutSelectedId;
        }


        $('.tem_sub_cnt').on('scroll', function () {

            if (isIE()) {
                if ($(this).scrollTop() + $(this).innerHeight() >= $(this)[0].scrollHeight - 10) {
                    if (!(totalPageCnt == currentPageNo)) {
                        searchLayout(currentPageNo++);
                    }
                }
            }
            else {
                if ($(this).scrollTop() + $(this).innerHeight() >= $(this)[0].scrollHeight) {
                    if (!(totalPageCnt == currentPageNo)) {
                        searchLayout(currentPageNo++);
                    }
                }
            }
        });


        // 레이아웃 최초 조회
        currentPageNo++;
        searchLayout();

    </script>
}
