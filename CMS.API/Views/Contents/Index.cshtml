        // 컨텐츠 업로드 팝업의 컨텐츠 타입 변경 이벤트 함수
        $M_CONTENT_TYPE.change(function () {

            $('#FILE_AREA').css('display', 'none');
            $('#TEXT_AREA').css('display', 'none');
            $('#URL_AREA').css('display',  'none');

            switch ($(this).val().toUpperCase()) {
                case 'T':
                    $('#TEXT_AREA').css('display', 'table-row');
                    break;
                case 'U':
                    $('#URL_AREA').css('display', 'table-row');
                    break;
                case 'I':
                case 'B':
                case 'H':
                    $('#FILE_AREA').css('display', 'table-row');
                    $('#FILE_NM').attr('accept', 'image/*');
                    break;
                case 'M':
                    $('#FILE_AREA').css('display', 'table-row');
                    $('#FILE_NM').attr('accept', 'video/mp4,video/x-m4v,video/*');
                    break;
            }
        });

